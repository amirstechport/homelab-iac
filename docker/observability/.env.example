# =============================================================================
# Observability Stack — Environment Variables
# homelab-iac | docker/observability/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# ── Config & Data Directory ───────────────────────────────────────────────────
# Absolute path on the host for Prometheus and Promtail config files.
# Structure expected:
#   ${OBSERVABILITY_DATA_DIR}/prometheus/prometheus.yml
#   ${OBSERVABILITY_DATA_DIR}/promtail/promtail-config.yaml
# Example: /home/youruser/observability
OBSERVABILITY_DATA_DIR=/path/to/your/observability

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin credentials — change these immediately after first login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_strong_password

# Host port for Grafana UI. Default: 3000
GRAFANA_PORT=3000

# ── Prometheus ────────────────────────────────────────────────────────────────
# Host port for Prometheus UI. Default: 9090
PROMETHEUS_PORT=9090

# ── Node Exporter ─────────────────────────────────────────────────────────────
# Host port for node_exporter metrics. Default: 9100
# Must be reachable by Prometheus scrape targets config.
NODE_EXPORTER_PORT=9100

# ── Loki ──────────────────────────────────────────────────────────────────────
# Host port for Loki API. Default: 3100
# Grafana datasource URL: http://loki:3100
LOKI_PORT=3100

# ── Promtail ──────────────────────────────────────────────────────────────────
# Syslog receiver port — configure your firewall/router to forward to this port
# Default: 1514 (standard syslog alt port, avoids needing root for 514)
PROMTAIL_SYSLOG_PORT=1514
