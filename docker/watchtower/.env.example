# =============================================================================
# Watchtower — Environment Variables
# homelab-iac | docker/watchtower/.env.example
# =============================================================================
#
# HOW TO USE:
#   cp .env.example .env
#   nano .env    # Fill in your real values
#
# SECURITY:
#   - Never commit .env to version control
#   - .env is listed in .gitignore
#   - This .env.example file is safe to commit — it contains no real secrets
#
# =============================================================================

# ── Slack Notifications ───────────────────────────────────────────────────────
# Create an Incoming Webhook: Slack App Directory → Incoming Webhooks → Add to Slack
# Paste the webhook URL you receive from Slack below.
WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=YOUR_SLACK_WEBHOOK_URL

# ── Update Schedule ───────────────────────────────────────────────────────────
# How often Watchtower checks for new images, in seconds.
# 86400  = every 24 hours  (recommended for stable homelab)
# 43200  = every 12 hours
# 3600   = every 1 hour    (aggressive — not recommended for production)
WATCHTOWER_POLL_INTERVAL=86400

# ── Cleanup ───────────────────────────────────────────────────────────────────
# Remove old (superseded) images automatically after a container is updated.
# Keeps disk usage clean. Set to false to retain old images for rollback.
WATCHTOWER_CLEANUP=true

# ── Stopped Container Behaviour ───────────────────────────────────────────────
# Check stopped containers for updates? (true/false)
WATCHTOWER_INCLUDE_STOPPED=false

# Restart previously stopped containers after updating their image? (true/false)
WATCHTOWER_REVIVE_STOPPED=false

# ── Error Handling ────────────────────────────────────────────────────────────
# What to do when image HEAD cannot be fetched (e.g., registry is unreachable).
# Options: always | never | auto
WATCHTOWER_WARN_ON_HEAD_FAILURE=never

# ── Notifications ─────────────────────────────────────────────────────────────
# Send a single summary report per check cycle instead of one message per update.
# Strongly recommended — keeps your Slack channel readable.
WATCHTOWER_NOTIFICATION_REPORT=true

# ── Docker API ────────────────────────────────────────────────────────────────
# Pinned Docker API version. Check your Docker version with: docker version
# And match accordingly. Prevents API mismatch errors after Docker upgrades.
DOCKER_API_VERSION=1.47
