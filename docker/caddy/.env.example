# =============================================================================
# Caddy — Environment Variables
# homelab-iac | docker/caddy/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# Absolute path to the directory containing your Caddy data on the host.
# This directory must contain a valid Caddyfile before starting the stack.
# Example: /home/youruser/caddy
CADDY_DATA_DIR=/path/to/your/caddy
