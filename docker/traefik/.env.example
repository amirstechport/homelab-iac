# =============================================================================
# Traefik — Environment Variables
# homelab-iac | docker/traefik/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# ── Data Directory ────────────────────────────────────────────────────────────
# Absolute path on the host where all Traefik config and data lives.
# This directory must contain: traefik.yml, acme.json, cf_api_token.txt
# Example: /home/youruser/traefik
TRAEFIK_DATA_DIR=/path/to/your/traefik

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Subdomain where the Traefik dashboard will be accessible.
# Example: traefik.yourdomain.com
TRAEFIK_DASHBOARD_HOST=traefik.yourdomain.com

# Basic auth credentials for the dashboard.
# Generate with: htpasswd -nb yourusername yourpassword
# The output will look like: yourusername:$apr1$xxxxx...
# IMPORTANT: Escape any $ in the hash with $$ in this file.
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$xxxxxxxxxx

# ── TLS / Cloudflare ──────────────────────────────────────────────────────────
# Your root domain. Traefik will obtain a wildcard cert for *.yourdomain.com
TRAEFIK_CERT_DOMAIN=yourdomain.com

# The Cloudflare API token goes in cf_api_token.txt (not here).
# Create it at: Cloudflare → My Profile → API Tokens → Create Token
# Required permissions: Zone → DNS → Edit (scoped to your zone)
# Then: echo "your_token" > ${TRAEFIK_DATA_DIR}/cf_api_token.txt
#       chmod 600 ${TRAEFIK_DATA_DIR}/cf_api_token.txt

# ── No-Proxy ──────────────────────────────────────────────────────────────────
# Comma-separated hostnames/patterns that bypass Traefik's proxy.
# Example for Tailscale: *.ts.net
NO_PROXY=
