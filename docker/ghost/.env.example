# =============================================================================
# Ghost Blog — Environment Variables
# homelab-iac | docker/ghost/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# ── Database Credentials ──────────────────────────────────────────────────────
# Root password for MariaDB (used internally only — never exposed externally)
GHOST_DB_ROOT_PASSWORD=change_this_strong_root_password

# Ghost application database credentials
GHOST_DB_NAME=ghost
GHOST_DB_USER=ghost_u
GHOST_DB_PASSWORD=change_this_strong_db_password

# ── Ghost Site URL ────────────────────────────────────────────────────────────
# The public URL of your Ghost site. Must include protocol (http/https).
# For local/LAN use:       http://192.168.1.100:2368
# Behind a reverse proxy:  https://blog.yourdomain.com
# IMPORTANT: Ghost uses this URL to generate links — wrong URL = broken emails
GHOST_URL=https://blog.yourdomain.com

# ── Data Storage ──────────────────────────────────────────────────────────────
# Absolute path on the HOST where Ghost and MariaDB data is stored.
# Both services use subdirectories under this path:
#   ${GHOST_DATA_DIR}/db    → MariaDB data files
#   ${GHOST_DATA_DIR}/data  → Ghost content (themes, images, files)
# Example: /home/youruser/ghost
GHOST_DATA_DIR=/path/to/your/ghost

# ── Port ──────────────────────────────────────────────────────────────────────
# Host port Ghost is accessible on. Default: 2368
# If running behind a reverse proxy, you can leave this as 2368 and proxy to it.
GHOST_PORT=2368
