# =============================================================================
# Deunhealth — Environment Variables
# homelab-iac | docker/deunhealth/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
#
# Deunhealth requires no secrets. All values have safe defaults.
# =============================================================================

# Log verbosity. Options: debug | info | warning | error
DEUNHEALTH_LOG_LEVEL=info

# Your timezone — used for log timestamps
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York
