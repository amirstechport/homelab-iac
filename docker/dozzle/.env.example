# =============================================================================
# Dozzle — Environment Variables
# homelab-iac | docker/dozzle/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
#
# Dozzle requires no secrets to run. All values here have safe defaults.
# Copy this file only if you want to override the defaults.
# =============================================================================

# Host port Dozzle is accessible on. Default: 9999
# Access at: http://YOUR_HOST_IP:${DOZZLE_PORT}
DOZZLE_PORT=9999

# Log verbosity for the Dozzle process itself (not the containers it watches)
# Options: debug | info | warn | error
DOZZLE_LEVEL=info
