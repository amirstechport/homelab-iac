# =============================================================================
# Cloudflare Tunnel — Environment Variables
# homelab-iac | docker/cloudflared/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# ── Tunnel Token ──────────────────────────────────────────────────────────────
# Obtained from: Cloudflare Zero Trust → Networks → Tunnels → Create Tunnel
# The token is shown in the install command on the connector setup page.
# Treat this like a password — it authorises your connector to Cloudflare.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
