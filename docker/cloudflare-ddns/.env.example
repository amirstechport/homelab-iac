# =============================================================================
# Cloudflare DDNS — Environment Variables
# homelab-iac | docker/cloudflare-ddns/.env.example
# =============================================================================
# cp .env.example .env  →  fill in your values  →  never commit .env
# =============================================================================

# ── Cloudflare API Token ──────────────────────────────────────────────────────
# Create at: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Use the "Edit zone DNS" template and scope it to your specific zone only.
# Minimum permissions required: Zone → DNS → Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ── Domains to Update ─────────────────────────────────────────────────────────
# Comma-separated list. All domains must be in zones your API token can edit.
# Examples:
#   Single domain:    yourdomain.com
#   Root + www:       yourdomain.com,www.yourdomain.com
#   Multiple zones:   domain1.com,sub.domain2.com
CF_DOMAINS=yourdomain.com,www.yourdomain.com

# ── Cloudflare Proxy ─────────────────────────────────────────────────────────
# true  — traffic routes through Cloudflare CDN (hides your real IP, enables WAF)
# false — DNS resolves directly to your IP (required for most self-hosted services
#         that use their own TLS, e.g. Caddy, Traefik, plain SSH)
CF_PROXIED=false

# ── IPv6 ──────────────────────────────────────────────────────────────────────
# none       — disable IPv6 updates (most homelab use cases)
# local      — detect from local network interface
# cloudflare — ask Cloudflare what your IPv6 is
CF_IP6_PROVIDER=none

# ── Container User ────────────────────────────────────────────────────────────
# UID:GID the container runs as. Match to a non-root user on your host.
# Find yours with: id -u && id -g
CF_DDNS_USER=1000:1000
